# ===========================================
# Sneho Backend — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=https://careconnect-orpin.vercel.app/
CLIENT_URLS=https://careconnect-orpin.vercel.app/
ALLOW_VERCEL_PREVIEW_ORIGINS=true

# Database (MongoDB)
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"

# JWT Authentication
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# OpenAI (Optional — for AI chatbot)
OPENAI_API_KEY=sk-...

# Stripe (Optional — for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stream (Optional — for video)
STREAM_API_KEY=your_stream_api_key
STREAM_SECRET_KEY=your_stream_secret_key
